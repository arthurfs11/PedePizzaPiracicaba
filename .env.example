# ── Token do Bot Telegram ──────────────────────────────────
# Obtenha com o @BotFather no Telegram
BOT_TOKEN=8241504524:AAFmWcRQDgM_eR3AlIecZwrxFwUCn3a13r0

# ── Credenciais do n8n ─────────────────────────────────────
N8N_USER=admin
N8N_PASS=pizza123

# ── URL do webhook n8n (para o bot) ───────────────────────
# Dentro do Docker: http://n8n:5678/webhook/direciona-pedido
# Em desenvolvimento local: http://localhost:5678/webhook/direciona-pedido
N8N_WEBHOOK_URL=http://n8n:5678/webhook/direciona-pedido

# ── Pix ────────────────────────────────────────────────────
# Chave Pix da pizzaria (email, CPF, CNPJ, telefone ou chave aleatória do banco)
PIX_KEY=pagamentos@suapizzaria.com.br
PIX_NOME=Sua Pizzaria
PIX_CIDADE=Sua Cidade

# ── Dashboard ──────────────────────────────────────────────
# Porta do dashboard (padrão: 8000)
PORT=8000

# ── AbacatePay (pagamentos Pix automáticos) ────────────────
# Deixe em branco para desativar (usa Pix manual como fallback)
# Obtenha sua API key em: https://app.abacatepay.com
#ABACATEPAY_API_KEY=
# URL de retorno após pagamento (opcional, requer domínio público)
#ABACATEPAY_RETURN_URL=
# Secret para validar webhooks (coloque qualquer string aleatória)
#ABACATEPAY_WEBHOOK_SECRET=
# URL do seu dashboard para receber webhooks (configure em app.abacatepay.com)
# Exemplo: https://meudominio.com/api/webhooks/abacatepay?secret=SEU_SECRET
